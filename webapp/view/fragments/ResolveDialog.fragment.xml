<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="resolveDialog"
        title="Resolve Ticket"
        contentWidth="360px"
        resizable="false"
        draggable="false">

        <subHeader>
            <Toolbar>
                <Text text="Please provide resolution details before closing this ticket."/>
            </Toolbar>
        </subHeader>

        <content>
            <VBox class="sapUiSmallMarginBeginEnd sapUiMediumMarginTopBottom">

                <Label text="Ticket" class="sapUiTinyMarginBottom"/>
                <Text text="{detailModel>/requestNumber}" class="ticketNumber sapUiSmallMarginBottom"/>

                <Label text="Issue" class="sapUiSmallMarginTop sapUiTinyMarginBottom"/>
                <Text text="{detailModel>/issueDescription}" wrapping="true" maxLines="2" class="ticketDescription sapUiSmallMarginBottom"/>

                <Label text="Resolution Notes" required="true" class="sapUiSmallMarginTop sapUiTinyMarginBottom"/>
                <TextArea
                    id="resolutionNotesInput"
                    rows="5"
                    growing="true"
                    growingMaxLines="8"
                    width="100%"
                    placeholder="Describe what was done to resolve this issue..."
                    valueLiveUpdate="true"
                    valueStateText="Resolution notes are required"/>

                <Label text="Resolution Time" class="sapUiSmallMarginTop sapUiTinyMarginBottom"/>
                <DateTimePicker
                    id="resolutionTimePicker"
                    width="100%"
                    valueFormat="yyyy-MM-dd'T'HH:mm:ss"
                    displayFormat="dd MMM yyyy, HH:mm"
                    value="{detailModel>/actualResolutionTimestamp}"/>

            </VBox>
        </content>

        <beginButton>
            <Button
                text="Submit Resolution"
                type="Emphasized"
                icon="sap-icon://accept"
                press=".onConfirmResolve"/>
        </beginButton>
        <endButton>
            <Button
                text="Cancel"
                type="Default"
                press=".onCancelResolve"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>
