{
  "_version": "1.84.0",
  "sap.app": {
    "id": "com.wipro.earmms.technician.app.earmmstechnicianapp",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "1.0.0"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.24.0",
      "toolsId": "a383b740-2485-4923-88df-5fbfafba483e"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.147.2",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.uxap": {},
        "sap.f": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.wipro.earmms.technician.app.earmmstechnicianapp.i18n.i18n"
        }
      },
      "repair": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/mockdata/repairRequests.json"
      },
      "technician": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "model/mockdata/technician.json"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.wipro.earmms.technician.app.earmmstechnicianapp.view",
        "async": true,
        "viewPath": "com.wipro.earmms.technician.app.earmmstechnicianapp.view"
      },
      "routes": [
        {
          "name": "workQueue",
          "pattern": "",
          "target": ["TargetWorkQueue"]
        },
        {
          "name": "ticketDetail",
          "pattern": "ticket/{requestId}",
          "target": ["TargetTicketDetail"]
        }
      ],
      "targets": {
        "TargetWorkQueue": {
          "id": "WorkQueue",
          "name": "WorkQueue"
        },
        "TargetTicketDetail": {
          "id": "TicketDetail",
          "name": "TicketDetail"
        }
      }
    },
    "rootView": {
      "viewName": "com.wipro.earmms.technician.app.earmmstechnicianapp.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}
